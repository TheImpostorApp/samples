# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/

# Per-workspace run history / local-only state (mock-workspace/.impostor/history.jsonl)
.impostor/

# Secrets — but keep the bundled workspace's environment, which holds only localhost
# vars (no secrets) and would otherwise be swallowed by the broad rules below.
.env
.env.*
!mock-workspace/.env/
!mock-workspace/.env/**
